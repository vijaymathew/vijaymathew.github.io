#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
BOOK_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
PROJECTS_ROOT="$(cd -- "$SCRIPT_DIR/../../../.." && pwd)"
NEX_ROOT="$PROJECTS_ROOT/nex"
FILES=()

if [[ -f "$BOOK_ROOT/preface.md" ]]; then
  FILES+=("$BOOK_ROOT/preface.md")
fi

for n in $(seq 1 12); do
  file="$BOOK_ROOT/chapter_${n}.md"
  if [[ -f "$file" ]]; then
    FILES+=("$file")
  fi
done

if [[ -f "$BOOK_ROOT/toc.md" ]]; then
  FILES+=("$BOOK_ROOT/toc.md")
fi

cd "$NEX_ROOT"
exec clojure -M:test test/scripts/check_algo_book_examples.clj --root "$BOOK_ROOT" "$@" "${FILES[@]}"
